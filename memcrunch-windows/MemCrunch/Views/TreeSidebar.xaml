<UserControl x:Class="MemCrunch.Views.TreeSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
        <ItemsControl ItemsSource="{Binding SidebarChildren}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8,4" Margin="1" CornerRadius="4" Cursor="Hand"
                            MouseLeftButtonDown="Node_Click" Background="Transparent">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#10FFFFFF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" FontSize="13" Margin="0,0,6,0"
                                           Text="{Binding IsDir, Converter={x:Static local:DirIconConverter.Instance}}" />
                                <TextBlock Text="{Binding Name}" FontSize="12" TextTrimming="CharacterEllipsis"
                                           Foreground="{StaticResource TextPrimary}" />
                            </DockPanel>
                            <DockPanel Margin="20,2,0,0">
                                <TextBlock DockPanel.Dock="Left" FontSize="10"
                                           Foreground="{StaticResource TextSecondary}"
                                           Text="{Binding Size, Converter={StaticResource SizeConverter}}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
