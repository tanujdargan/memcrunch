<UserControl x:Class="MemCrunch.Views.ScanProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
        <Border Background="#0AFFFFFF" CornerRadius="16" Padding="32">
            <StackPanel HorizontalAlignment="Center" Width="260">
                <TextBlock Text="🔍" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12" />
                <TextBlock Text="Scanning..." FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16" />

                <!-- Progress bar -->
                <Grid Height="8" Margin="0,0,0,4">
                    <Border Background="#374151" CornerRadius="4" />
                    <Border Background="{StaticResource AccentBlue}" CornerRadius="4" HorizontalAlignment="Left">
                        <Border.Width>
                            <Binding Path="ProgressFraction" Converter="{x:Static local:FractionToWidthConverter.Instance}"
                                     ConverterParameter="260" />
                        </Border.Width>
                    </Border>
                </Grid>

                <DockPanel Margin="0,0,0,16">
                    <TextBlock DockPanel.Dock="Left" FontSize="11" Foreground="{StaticResource AccentBlue}" FontWeight="Medium">
                        <TextBlock.Text>
                            <Binding Path="ProgressFraction" StringFormat="{}{0:P0}" />
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" FontSize="11"
                               Foreground="{StaticResource TextSecondary}"
                               Text="{Binding BytesScanned, Converter={StaticResource SizeConverter}}" />
                </DockPanel>

                <!-- Stats -->
                <UniformGrid Columns="2" Margin="0,0,0,12">
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,4">
                        <TextBlock Text="{Binding FilesScanned, Converter={StaticResource NumberConverter}}"
                                   FontSize="14" FontWeight="Medium" HorizontalAlignment="Center" />
                        <TextBlock Text="files" FontSize="10" Foreground="{StaticResource TextTertiary}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,4">
                        <TextBlock Text="{Binding DirsScanned, Converter={StaticResource NumberConverter}}"
                                   FontSize="14" FontWeight="Medium" HorizontalAlignment="Center" />
                        <TextBlock Text="folders" FontSize="10" Foreground="{StaticResource TextTertiary}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </UniformGrid>

                <!-- Current path -->
                <TextBlock Text="{Binding CurrentPath}" FontSize="10" Foreground="{StaticResource TextTertiary}"
                           TextTrimming="CharacterEllipsis" MaxWidth="260" Margin="0,0,0,12" />

                <Button Content="Cancel" Click="Cancel_Click" HorizontalAlignment="Center"
                        Padding="16,6" Background="Transparent" Foreground="{StaticResource TextSecondary}"
                        BorderBrush="{StaticResource TextTertiary}" BorderThickness="1">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
