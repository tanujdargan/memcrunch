<UserControl x:Class="MemCrunch.Views.VolumeSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="8">
            <StackPanel>
                <TextBlock Text="VOLUMES" FontSize="10" Foreground="{StaticResource TextTertiary}"
                           Margin="8,8,0,8" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding Volumes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" Margin="2" CornerRadius="6" Cursor="Hand"
                                    MouseLeftButtonDown="Volume_Click"
                                    Background="Transparent">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#15FFFFFF" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <!-- Radio circle -->
                                    <Ellipse Width="16" Height="16" Stroke="{StaticResource TextTertiary}"
                                             StrokeThickness="1.5" Margin="0,0,8,0" VerticalAlignment="Top" />
                                    <!-- Volume icon + info -->
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimary}" />
                                        <TextBlock Text="{Binding MountPoint}" FontSize="10"
                                                   Foreground="{StaticResource TextTertiary}" Margin="0,2,0,0" />
                                        <!-- Usage bar -->
                                        <Grid Height="3" Margin="0,4,0,0" Width="180" HorizontalAlignment="Left">
                                            <Border Background="#374151" CornerRadius="1.5" />
                                            <Border Background="{StaticResource AccentBlue}" CornerRadius="1.5"
                                                    HorizontalAlignment="Left">
                                                <Border.Width>
                                                    <MultiBinding Converter="{x:Static local:UsageWidthConverter.Instance}">
                                                        <Binding Path="UsedBytes" />
                                                        <Binding Path="TotalBytes" />
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Grid>
                                        <TextBlock FontSize="10" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0">
                                            <Run Text="{Binding UsedBytes, Converter={StaticResource SizeConverter}, Mode=OneWay}" />
                                            <Run Text=" of " />
                                            <Run Text="{Binding TotalBytes, Converter={StaticResource SizeConverter}, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Scan button -->
        <Border Grid.Row="1" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="12">
            <Button Content="🔍  Scan" Click="Scan_Click" IsEnabled="{Binding CanScan}"
                    Padding="0,8" FontSize="13" FontWeight="Medium"
                    Background="{StaticResource AccentBlue}" Foreground="White"
                    BorderThickness="0" HorizontalAlignment="Stretch">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Border>
    </Grid>
</UserControl>
