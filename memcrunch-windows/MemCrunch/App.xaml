<Application x:Class="MemCrunch.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MemCrunch.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <conv:SizeConverter x:Key="SizeConverter" />
        <conv:NumberConverter x:Key="NumberConverter" />
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
        <conv:HexColorConverter x:Key="HexColor" />

        <!-- Dark theme colors -->
        <SolidColorBrush x:Key="BgDark" Color="#111827" />
        <SolidColorBrush x:Key="BgPanel" Color="#1F2937" />
        <SolidColorBrush x:Key="BgHover" Color="#374151" />
        <SolidColorBrush x:Key="Border" Color="#1F2937" />
        <SolidColorBrush x:Key="TextPrimary" Color="#E5E7EB" />
        <SolidColorBrush x:Key="TextSecondary" Color="#9CA3AF" />
        <SolidColorBrush x:Key="TextTertiary" Color="#6B7280" />
        <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6" />
    </Application.Resources>
</Application>
