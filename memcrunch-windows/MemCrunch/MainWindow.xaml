<Window x:Class="MemCrunch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MemCrunch.Views"
        Title="MemCrunch" Width="1200" Height="800" MinWidth="800" MinHeight="600"
        Background="{StaticResource BgDark}"
        Foreground="{StaticResource TextPrimary}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#0AFFFFFF" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <DockPanel Margin="8,0">
                <!-- Left: Back + Up -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="◀" Click="BackToVolumes_Click" Padding="6,4" Margin="0,0,4,0"
                            Visibility="{Binding ScanComplete, Converter={StaticResource BoolVis}}"
                            Background="Transparent" Foreground="{StaticResource TextSecondary}" BorderThickness="0"
                            ToolTip="Back to volumes" />
                    <Button Content="⬆" Click="NavigateUp_Click" Padding="6,4"
                            Visibility="{Binding ScanComplete, Converter={StaticResource BoolVis}}"
                            Background="Transparent" Foreground="{StaticResource TextSecondary}" BorderThickness="0"
                            ToolTip="Up to parent" />
                    <TextBlock Text="MemCrunch" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimary}" Margin="8,0,0,0" />
                </StackPanel>

                <!-- Right: Path pill + Stats pill -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding ScanComplete, Converter={StaticResource BoolVis}}">
                    <!-- Path pill -->
                    <Border Background="#0AFFFFFF" CornerRadius="12" Padding="10,4" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁 " FontSize="10" Foreground="{StaticResource TextTertiary}" />
                            <TextBlock Text="{Binding FullPath}" FontSize="11" Foreground="{StaticResource TextSecondary}"
                                       MaxWidth="300" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <!-- Stats pill -->
                    <Border Background="#0AFFFFFF" CornerRadius="12" Padding="10,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄 " FontSize="10" Foreground="{StaticResource TextTertiary}" />
                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}">
                                <Run Text="{Binding TotalSize, Converter={StaticResource SizeConverter}, Mode=OneWay}" FontWeight="Medium" />
                                <Run Text=" in " Foreground="{StaticResource TextTertiary}" />
                                <Run Text="{Binding TotalFiles, Converter={StaticResource NumberConverter}, Mode=OneWay}" />
                                <Run Text=" files" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Scanning status -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsScanning, Converter={StaticResource BoolVis}}">
                    <Border Background="#0AFFFFFF" CornerRadius="12" Padding="10,4" Margin="0,0,6,0">
                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}">
                            <Run Text="{Binding FilesScanned, Converter={StaticResource NumberConverter}, Mode=OneWay}" />
                            <Run Text=" files scanned" />
                        </TextBlock>
                    </Border>
                    <Button Content="✕" Click="CancelScan_Click" Padding="6,4"
                            Background="Transparent" Foreground="{StaticResource TextSecondary}" BorderThickness="0"
                            ToolTip="Cancel scan" />
                </StackPanel>

                <TextBlock /> <!-- spacer -->
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="300" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                <ContentPresenter x:Name="SidebarContent" />
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="Transparent" />

            <!-- Treemap -->
            <views:TreemapView Grid.Column="2" x:Name="TreemapPanel" />

            <!-- File type panel -->
            <Border Grid.Column="3" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0">
                <views:FileTypePanel x:Name="FileTypePanelView" />
            </Border>
        </Grid>
    </Grid>
</Window>
